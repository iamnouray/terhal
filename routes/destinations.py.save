from fastapi import APIRouter, HTTPException
from database import destinations_collection

router = APIRouter(prefix="/destinations", tags=["destinations"])

@router.get("/")
async def get_all_destinations():
    # Use to_list(length=None) to get all results asynchronously
places = list(destinations_collection.find({}, {"_id": 0}))ظ    places = await destinations_collection.find({}, {"_id": 0}).to_list(length=None)
    return {"count": len(places), "data": places}

@router.get("/search")
async def search_destinations(city: str = "", category: str = ""):
    query = {}
    if city: 
        query["city"] = {"$regex": city, "$options": "i"}
    if category: 
        query["category"] = {"$regex": category, "$options": "i"}
    
    # Use await for the async find operation
    results = await destinations_collection.find(query, {"_id": 0}).to_list(length=None)
    return {"count": len(results), "data": results}

@router.get("/{name}")
async def get_destination(name: str):
    # Use await for the find_one operation
    place = await destinations_collection.find_one({"name": name}, {"_id": 0})
    if not place:
        raise HTTPException(status_code=404, detail="Destination not found")
    return place
